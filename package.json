{
  "name": "ag-multi-account-switchboard",
  "displayName": "AG Multi-Account Switchboard",
  "description": "Switch between Antigravity accounts instantly. Monitor AI quotas, token budgets and reset timers — all in one sidebar panel.",
  "icon": "assets/icon.png",
  "version": "2.0.0",
  "publisher": "erennyuksel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erennyuksell/ag-multi-account-switchboard"
  },
  "homepage": "https://github.com/erennyuksell/ag-multi-account-switchboard#readme",
  "bugs": {
    "url": "https://github.com/erennyuksell/ag-multi-account-switchboard/issues"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "ai",
    "quota",
    "multi-account",
    "switchboard"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "enabledApiProposals": [
    "antigravityUnifiedStateSync"
  ],
  "activationEvents": [
    "onView:ag.quotaView",
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ag-switchboard",
          "title": "Antigravity",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "ag-switchboard": [
        {
          "type": "webview",
          "id": "ag.quotaView",
          "name": "Quota",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ag.refreshQuota",
        "title": "Antigravity: Refresh Quota",
        "icon": "$(refresh)"
      },
      {
        "command": "ag.addAccount",
        "title": "Antigravity: Add Tracked Account",
        "icon": "$(add)"
      },
      {
        "command": "ag.removeAccount",
        "title": "Antigravity: Remove Tracked Account",
        "icon": "$(trash)"
      },
      {
        "command": "ag.addAccountByToken",
        "title": "Antigravity: Add Account via Token",
        "icon": "$(key)"
      }
    ],
    "menus": {}
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish:ovsx": "ovsx publish *.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
